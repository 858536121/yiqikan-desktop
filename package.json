{
  "name": "yiqikan",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "pnpm -r build",
    "desktop": "pnpm --filter @yiqikan/desktop dev",
    "ws": "pnpm --filter @yiqikan/server dev",
    "web": "pnpm --filter @yiqikan/web dev",
    "deploy": "bash ./deploy.sh",
    "deploy:status": "pm2 status yiqikan-server yiqikan-web",
    "deploy:logs": "pm2 logs yiqikan-server yiqikan-web",
    "deploy:stop": "pm2 stop yiqikan-server yiqikan-web",
    "db:generate": "corepack pnpm --filter @yiqikan/web db:generate",
    "db:migrate": "corepack pnpm --filter @yiqikan/web db:migrate",
    "db:migrate:deploy": "corepack pnpm --filter @yiqikan/web db:migrate:deploy",
    "db:push": "corepack pnpm --filter @yiqikan/web db:push",
    "db:seed": "corepack pnpm --filter @yiqikan/web db:seed",
    "db:studio": "corepack pnpm --filter @yiqikan/web db:studio",
    "db:up": "docker compose --env-file .env.db -f docker-compose.db.yml up -d postgres",
    "db:down": "docker compose --env-file .env.db -f docker-compose.db.yml down",
    "db:logs": "docker compose --env-file .env.db -f docker-compose.db.yml logs -f postgres",
    "dist": "pnpm --filter @yiqikan/desktop dist",
    "dist:mac": "pnpm --filter @yiqikan/desktop dist:mac",
    "dist:win": "pnpm --filter @yiqikan/desktop dist:win",
    "publish:desktop": "bash scripts/publish-desktop.sh",
    "dist:linux": "pnpm --filter @yiqikan/desktop dist:linux",
    "lint": "pnpm -r lint",
    "test:server": "pnpm --filter @yiqikan/server test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "pm2": "^5.4.3"
  }
}
